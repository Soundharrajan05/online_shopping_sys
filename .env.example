# Environment Configuration Example
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Option 1: PostgreSQL Connection String (Recommended for Production)
# Format: postgresql://username:password@host:5432/database
# Example: postgresql://myuser:mypassword@localhost:5432/shopping_system
DATABASE_URL=postgresql://username:password@host:5432/database

# Option 2: MySQL Individual Variables (For Local Development)
# Uncomment these if using MySQL locally (comment out DATABASE_URL above)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_NAME=shopping_system
# DB_PORT=3306

# ============================================
# NOTES
# ============================================
# - If DATABASE_URL is set, it will be used (PostgreSQL)
# - If DATABASE_URL is not set, individual DB_* variables will be used (MySQL)
# - For Render.com: Use DATABASE_URL (automatically provided)
# - For local development: Use either option based on your database
